---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import PasteViewer from "../../components/PasteViewer";

const { id } = Astro.params;

let pasteContent = "";
let error = null;

try {
    const res = await fetch(`https://api.kyle.so/paste/${id}`);
    if (!res.ok) {
        if (res.status === 404) {
            return Astro.redirect("/404");
        }
        throw new Error("Failed to fetch paste");
    }
    const data = await res.json();
    pasteContent = data.text;
} catch (e) {
    error = e instanceof Error ? e.message : "An error occurred";
}
---

<Layout title={`Paste ${id}`} showFooter={false}>
    <Nav label="Paste" path="/paste" />
    <div class="flex-1 flex justify-center min-h-screen">
        <div class="w-full sm:w-[100%] md:w-[75%] lg:w-[55%] px-4 sm:px-8 py-8">
            <div class="flex items-start justify-between w-full mt-8 mb-8">
                <div class="flex flex-col item-start justify-center">
                    <h1 class="font-serif italic text-2xl">
                        Paste <span class="font-mono">{id}</span>
                    </h1>
                </div>
            </div>

            {
                error ? (
                    <div class="p-4 border border-red-500/50 bg-red-500/10 rounded-md text-red-500">
                        {error}
                    </div>
                ) : (
                    <div class="w-full relative group mt-8">
                        <PasteViewer content={pasteContent} client:load />
                    </div>
                )
            }
        </div>
    </div>
</Layout>
